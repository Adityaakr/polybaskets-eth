node_modules/
**/node_modules/
.npmrc

# ── builds / artifacts ──────────────────────────────────────────────────
dist/
build/
**/dist/
**/build/
target/
**/target/
*.tsbuildinfo

# ── editor / OS ─────────────────────────────────────────────────────────
.DS_Store
*.log
.vscode/
.idea/

# foundry build artifacts
contract/solidity/cache/
contract/solidity/out/
