# ── secrets — NEVER commit ──────────────────────────────────────────────
# deploy/.env.deploy holds the operator PRIVATE KEY. Do not commit any .env.
.env
.env.*
!.env.example
deploy/.env.deploy
deploy/relayer-state.json
# ethexe local working dir holds key material (keys/secp/*.json) + the binary
deploy/ethexe-work/
deploy/ethexe-bin
**/keys/secp/
*.keystore

